{
	"name": "@luna/base",
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/bun": "1.3.10",
		"typescript": "5.9.3"
	},
	"workspaces": [
		"./src/apps/*",
		"./src/packages/*"
	],
	"scripts": {
		"start:bot": "bun --smol src/apps/bot/init.ts",
		"start:backend": "bun --smol src/apps/backend/init.ts",
		"start:db-seed": "cd src/packages/database && bun db:seed",
		"pretty": "bunx biome format --write .",
		"deploy": "docker compose up -d --build",
		"deploy-db": "cd src/packages/database && bun db:migrate deploy"
	},
	"dependencies": {
		"@kyvrixon/utils": "github:kyvrixon/utils#v1.0.9"
	}
}
