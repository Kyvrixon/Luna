{
	"name": "@luna/database",
	"type": "module",
	"devDependencies": {
		"@types/pg": "8.20.0"
	},
	"dependencies": {
		"@prisma/adapter-pg": "7.5.0",
		"@prisma/client": "7.5.0",
		"prisma": "7.5.0"
	},
	"scripts": {
		"db:migrate": "bun --env-file='../../../.env' prisma migrate",
		"db:generate": "bun --env-file='../../../.env' prisma generate",
		"db:seed": "bun --env-file='../../../.env' prisma db seed",
		"db:init": "bun db:generate && bun db:migrate deploy && bun db:seed"
	}
}
