{
	"name": "@luna/database",
	"type": "module",
	"devDependencies": {},
	"dependencies": {
		"@prisma/adapter-libsql": "7.5.0",
		"@prisma/client": "7.5.0",
		"prisma": "7.5.0"
	},
	"scripts": {
		"db:migrate:prod": "bun --env-file='../../../.env.prod' prisma migrate",
		"db:generate:prod": "bun --env-file='../../../.env.prod' prisma generate",
		"db:seed:prod": "bun --env-file='../../../.env.prod' prisma db seed",
		"db:init:prod": "bun db:generate:prod && bun db:migrate:prod deploy && bun db:seed:prod",
		"~": "",
		"db:migrate:dev": "bun --env-file='../../../.env.dev' prisma migrate",
		"db:generate:dev": "bun --env-file='../../../.env.dev' prisma generate",
		"db:seed:dev": "bun --env-file='../../../.env.dev' prisma db seed",
		"db:init:dev": "bun db:generate:dev && bun db:migrate:dev deploy && bun db:seed:dev"
	}
}
