// ########################################
// #              Datasource              #
// ########################################
datasource main {
    provider     = "sqlite"
    relationMode = "foreignKeys"
}

// ########################################
// #              Generator               #
// ########################################
generator main {
    output                 = "../../.generated/prisma"
    runtime                = "bun"
    provider               = "prisma-client"
    moduleFormat           = "esm"
    compilerBuild          = "fast"
    previewFeatures        = []
    importFileExtension    = "ts"
    generatedFileExtension = "ts"
}

// ########################################
// #             Base Models              #
// ########################################
/// Discord Member
model User {
    userId String @id @unique
	
    afk        Afk?
}
